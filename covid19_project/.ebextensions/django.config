packages:
  yum:
    git: []
container_commands:
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
option_settings:
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: "covid19_project.settings"
    DJANGO_SECRET_KEY: "your-generated-secret-key"  # Or from .env
    DJANGO_DEBUG: "False"
  aws:elasticbeanstalk:container:python:
    WSGIPath: "covid19_project.wsgi:application"